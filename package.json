{
  "name": "kripipasta.com",
  "version": "0.3.0",
  "description": "Kripipasta — internet horror archive.",
  "author": "Vladimir Babin",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate:legacy": "tsx --env-file=.env src/migrate/run.ts",
    "db:migrate:verify": "tsx --env-file=.env src/migrate/verify.ts",
    "db:seed:dossiers": "tsx --env-file=.env src/seed/dossiers.ts",
    "build:redirects": "tsx --env-file=.env src/build/gen-legacy-redirects.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "next": "^16.2.11",
    "next-intl": "^4.13.3",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/he": "^1.2.3",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "he": "^1.2.0",
    "mysql2": "^3.23.1",
    "postcss": "^8.4.0",
    "prisma": "^7.9.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
