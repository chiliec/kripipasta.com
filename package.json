{
    "name": "creepypasta.ru",
    "version": "0.2.0",
    "description": "This is a repository with creepypasta archive sources.",
    "author": "Vladimir Babin",
    "license": "MIT",
    "homepage": "https://github.com/chiliec/creepypasta.ru#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/chiliec/creepypasta.ru.git"
    },
    "bugs": {
        "url": "https://github.com/chiliec/creepypasta.ru/issues"
    },
    "keywords": [
        "creepypasta"
    ],
    "main": "src/main.ts",
    "scripts": {
        "dev": "tsc-watch --onSuccess \"tsx ./src/main.ts\"",
        "start": "tsc && tsx ./src/main.ts",
        "start:force": "tsx ./src/main.ts",
        "typecheck": "tsc",
        "lint": "eslint . --ignore-pattern .github/",
        "format": "eslint . --fix --ignore-pattern .github/",
        "build": "tsc --noEmit false",
        "build:frontend": "npm --prefix src/server/frontend run build",
        "build:all": "npm run build && npm run build:frontend"
    },
    "dependencies": {
        "@hono/node-server": "^1.19.7",
        "dotenv": "^17.2.3",
        "hono": "^4.11.3",
        "mongoose": "^9.0.2",
        "pino": "^10.1.0",
        "pino-pretty": "^13.1.3",
        "tsx": "^4.21.0",
        "znv": "^0.5.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^6.7.1",
        "@types/node": "^25.0.3",
        "eslint": "^9.39.2",
        "eslint-plugin-vue": "^10.6.2",
        "tsc-watch": "^7.2.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.0"
    }
}
