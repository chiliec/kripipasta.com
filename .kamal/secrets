# shellcheck shell=bash
# shellcheck disable=SC2034  # Vars consumed by Kamal externally.
# Pulls credentials from the sibling infrastructure repo's SOPS files.
# Kamal parses this file with dotenv (NOT bash): plain assignment + $(...) work,
# but bash default-expansion ${VAR:-default} does not — keep this a literal.
INFRA=../../infra

# GHCR pull/push token (shared across all apps).
KAMAL_REGISTRY_PASSWORD=$(sops -d --extract '["docker_registry_password"]' "$INFRA/secrets/shared.enc.yaml")

# Per-app secrets. `make add-app APP=kripipasta DB=postgres` writes db_uri;
# admin_password / admin_session_secret are added via `sops secrets/apps/kripipasta.enc.yaml`.
APP=$(sops -d "$INFRA/secrets/apps/kripipasta.enc.yaml")
DATABASE_URL=$(echo "$APP" | yq -r '.db_uri')
ADMIN_PASSWORD=$(echo "$APP" | yq -r '.admin_password')
ADMIN_SESSION_SECRET=$(echo "$APP" | yq -r '.admin_session_secret')
