{
    "compilerOptions": {
        "target": "ES2021",
        "lib": ["ES2022"],
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "rootDir": ".",
        "module": "ES2022",
        "moduleResolution": "Node",
        "paths": {
            "#root/*": ["./src/*"]
        },
        "allowImportingTsExtensions": true,
        "strict": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": true,
        "outDir": "build",
        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "preserveWatchOutput": true
    },
    "include": ["src/**/*"],
    "exclude": ["src/backend/frontend/*", "node_modules", "build"]
}
